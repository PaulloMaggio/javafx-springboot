<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="20.0" style="-fx-background-color: #F4F7F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafx_springboot.demo.controllers.StockController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Button onAction="#onBtnBackAction" prefHeight="35.0" style="-fx-background-color: #7F8C8D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="← VOLTAR" />
                <VBox spacing="5.0">
                    <children>
                        <Label text="RELATÓRIO" textFill="#7F8C8D">
                            <font> <Font name="Segoe UI Bold" size="14.0" /> </font>
                        </Label>
                        <Label text="Estoque Geral" textFill="#2C3E50">
                            <font> <Font name="Segoe UI Bold" size="28.0" /> </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
        
        <HBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #DCE3E8; -fx-border-radius: 10;">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Filtrar por nome" textFill="#34495E" />
                    <TextField fx:id="txtSearch" onKeyReleased="#updateFilters" prefHeight="35.0" promptText="Digite o nome..." style="-fx-background-radius: 5;" />
                </VBox>
                <VBox spacing="5.0" prefWidth="250.0">
                    <Label text="Filtrar por Departamento" textFill="#34495E" />
                    <ComboBox fx:id="comboDeptFilter" onAction="#updateFilters" prefHeight="35.0" prefWidth="250.0" promptText="Todos os Departamentos" style="-fx-background-radius: 5;" />
                </VBox>
                <VBox alignment="BOTTOM_CENTER">
                    <Button onAction="#clearFilters" prefHeight="35.0" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 5;" text="LIMPAR" />
                </VBox>
            </children>
        </HBox>

        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
          <columns>
            <TableColumn fx:id="columnId" maxWidth="60.0" text="ID" />
            <TableColumn fx:id="columnName" prefWidth="200.0" text="PRODUTO" />
            <TableColumn fx:id="columnDepartment" prefWidth="150.0" text="DEPARTAMENTO" />
            <TableColumn fx:id="columnPrice" maxWidth="120.0" text="PREÇO UNIT." />
          </columns>
          <columnResizePolicy>
             <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
          </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="30.0" style="-fx-background-color: #2C3E50; -fx-padding: 15; -fx-background-radius: 10;">
            <children>
                <VBox>
                    <children>
                        <Label text="ITENS NA VISUALIZAÇÃO" textFill="#BDC3C7">
                            <font> <Font name="Segoe UI" size="12.0" /> </font>
                        </Label>
                        <Label fx:id="lblTotalItems" text="0" textFill="WHITE">
                            <font> <Font name="Segoe UI Bold" size="20.0" /> </font>
                        </Label>
                    </children>
                </VBox>
                <VBox>
                    <children>
                        <Label text="SOMA PARCIAL (FILTRADA)" textFill="#BDC3C7">
                            <font> <Font name="Segoe UI" size="12.0" /> </font>
                        </Label>
                        <Label fx:id="lblTotalValue" text="R$ 0,00" textFill="#16A085">
                            <font> <Font name="Segoe UI Bold" size="20.0" /> </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>