<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="850.0" spacing="25.0" style="-fx-background-color: #F4F7F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafx_springboot.demo.controllers.MenuController">
   <children>
      <VBox alignment="CENTER" spacing="5.0">
         <children>
            <Label text="SISTEMA DE GESTÃO" textFill="#7F8C8D">
               <font>
                  <Font name="Segoe UI Bold" size="14.0" />
               </font>
            </Label>
            <Label text="Dashboard Administrativo" textFill="#2C3E50">
               <font>
                  <Font name="Segoe UI Bold" size="32.0" />
               </font>
            </Label>
         </children>
         <VBox.margin>
            <Insets bottom="30.0" />
         </VBox.margin>
      </VBox>
      
      <Button fx:id="btnProduct" minWidth="300.0" onAction="#onBtnProductAction" prefHeight="60.0" style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10; -fx-cursor: hand;" text="📦 GESTÃO DE PRODUTOS">
         <effect>
            <DropShadow height="10.0" radius="4.5" width="10.0">
               <color>
                  <Color opacity="0.15" />
               </color>
            </DropShadow>
         </effect>
      </Button>
      
      <Button fx:id="btnDepartment" minWidth="300.0" onAction="#onBtnDepartmentAction" prefHeight="60.0" style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10; -fx-cursor: hand;" text="🏢 DEPARTAMENTOS">
         <effect>
            <DropShadow height="10.0" radius="4.5" width="10.0">
               <color>
                  <Color opacity="0.15" />
               </color>
            </DropShadow>
         </effect>
      </Button>
      
      <Button fx:id="btnStock" minWidth="300.0" onAction="#onBtnStockAction" prefHeight="60.0" style="-fx-background-color: #16A085; -fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10; -fx-cursor: hand;" text="📊 CONTROLE DE ESTOQUE">
         <effect>
            <DropShadow height="10.0" radius="4.5" width="10.0">
               <color>
                  <Color opacity="0.15" />
               </color>
            </DropShadow>
         </effect>
      </Button>
      
      <Label text="Powered by Spring Boot &amp; JavaFX" textFill="#BDC3C7">
         <font>
            <Font name="Segoe UI" size="12.0" />
         </font>
         <VBox.margin>
            <Insets top="50.0" />
         </VBox.margin>
      </Label>
   </children>
</VBox>