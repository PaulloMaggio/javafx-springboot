<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="500.0" spacing="25.0" style="-fx-background-color: #F4F7F9; -fx-border-color: #DCE3E8; -fx-border-width: 2; -fx-border-radius: 15; -fx-background-radius: 15;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafx_springboot.demo.controllers.MenuController">
   <children>
      <VBox alignment="CENTER" spacing="5.0">
         <children>
            <Label text="DASHBOARD" textFill="#7F8C8D">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <Label text="Gestão de Inventário" textFill="#2C3E50">
               <font>
                  <Font name="Segoe UI Bold" size="30.0" />
               </font>
            </Label>
         </children>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </VBox>
      
      <Button fx:id="btnProduct" minWidth="280.0" onAction="#onBtnProductAction" prefHeight="55.0" style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 30; -fx-cursor: hand;" text="📦 CADASTRO DE PRODUTOS">
         <effect>
            <DropShadow height="15.0" radius="7.0" width="15.0">
               <color>
                  <Color opacity="0.2" />
               </color>
            </DropShadow>
         </effect>
      </Button>
      
      <Button fx:id="btnDepartment" minWidth="280.0" onAction="#onBtnDepartmentAction" prefHeight="55.0" style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 30; -fx-cursor: hand;" text="🏢 DEPARTAMENTOS">
         <effect>
            <DropShadow height="15.0" radius="7.0" width="15.0">
               <color>
                  <Color opacity="0.2" />
               </color>
            </DropShadow>
         </effect>
      </Button>
      
      <Button fx:id="btnStock" minWidth="280.0" onAction="#onBtnStockAction" prefHeight="55.0" style="-fx-background-color: #16A085; -fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 30; -fx-cursor: hand;" text="📊 VISUALIZAR ESTOQUE">
         <effect>
            <DropShadow height="15.0" radius="7.0" width="15.0">
               <color>
                  <Color opacity="0.2" />
               </color>
            </DropShadow>
         </effect>
      </Button>
      
      <Label text="Powered by Spring Boot &amp; JavaFX" textFill="#BDC3C7">
         <font>
            <Font size="11.0" />
         </font>
         <VBox.margin>
            <Insets top="30.0" />
         </VBox.margin>
      </Label>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>