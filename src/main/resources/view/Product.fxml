<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="20.0" style="-fx-background-color: #F4F7F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafx_springboot.demo.controllers.ProductController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Button onAction="#onBtnBackAction" prefHeight="35.0" style="-fx-background-color: #7F8C8D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="← VOLTAR" />
                <VBox spacing="5.0">
                    <children>
                        <Label text="CADASTRO" textFill="#7F8C8D">
                            <font> <Font name="Segoe UI Bold" size="14.0" /> </font>
                        </Label>
                        <Label text="Gestão de Produtos" textFill="#2C3E50">
                            <font> <Font name="Segoe UI Bold" size="28.0" /> </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
        
        <HBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #DCE3E8; -fx-border-radius: 10;">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Nome" textFill="#34495E" />
                    <TextField fx:id="txtName" prefHeight="35.0" style="-fx-background-radius: 5;" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Descrição" textFill="#34495E" />
                    <TextField fx:id="txtDescription" prefHeight="35.0" style="-fx-background-radius: 5;" />
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Preço" textFill="#34495E" />
                    <TextField fx:id="txtPrice" prefHeight="35.0" prefWidth="100.0" style="-fx-background-radius: 5;" />
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Departamento" textFill="#34495E" />
                    <ComboBox fx:id="comboDepartment" prefHeight="35.0" prefWidth="180.0" promptText="Selecione..." style="-fx-background-radius: 5;" />
                </VBox>
                <HBox alignment="BOTTOM_CENTER" spacing="10.0">
                    <Button fx:id="btnSave" onAction="#onBtnSaveAction" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #16A085; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="SALVAR" />
                    <Button fx:id="btnDelete" onAction="#onBtnDeleteAction" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="EXCLUIR" visible="false" />
                </HBox>
            </children>
        </HBox>

        <TableView fx:id="tableView" onMouseClicked="#onTableMouseClicked" VBox.vgrow="ALWAYS">
          <columns>
            <TableColumn fx:id="columnId" maxWidth="60.0" text="ID" />
            <TableColumn fx:id="columnName" prefWidth="150.0" text="NOME" />
            <TableColumn fx:id="columnDescription" prefWidth="250.0" text="DESCRIÇÃO" />
            <TableColumn fx:id="columnPrice" maxWidth="100.0" text="PREÇO" />
            <TableColumn fx:id="columnDepartment" prefWidth="150.0" text="DEPARTAMENTO" />
          </columns>
          <columnResizePolicy>
             <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
          </columnResizePolicy>
        </TableView>
    </children>
</VBox>