<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #F4F7F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafx_springboot.demo.controllers.DepartmentController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Button onAction="#onBtnBackAction" prefHeight="35.0" style="-fx-background-color: #7F8C8D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="← VOLTAR" />
                <VBox spacing="5.0">
                    <children>
                        <Label text="CONFIGURAÇÃO" textFill="#7F8C8D">
                            <font> <Font name="Segoe UI Bold" size="14.0" /> </font>
                        </Label>
                        <Label text="Gestão de Departamentos" textFill="#2C3E50">
                            <font> <Font name="Segoe UI Bold" size="28.0" /> </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
        
        <HBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #DCE3E8; -fx-border-radius: 10;">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Nome do Departamento" textFill="#34495E" />
                    <TextField fx:id="txtName" prefHeight="35.0" promptText="Ex: Eletrônicos, Alimentos, Limpeza..." style="-fx-background-radius: 5;" />
                </VBox>
                <VBox alignment="BOTTOM_CENTER">
                    <Button onAction="#onBtnSaveAction" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="CADASTRAR" />
                </VBox>
            </children>
        </HBox>

        <TableView fx:id="tableView" style="-fx-background-radius: 10; -fx-border-radius: 10;" VBox.vgrow="ALWAYS">
          <columns>
            <TableColumn fx:id="columnId" maxWidth="100.0" minWidth="80.0" prefWidth="90.0" text="ID" />
            <TableColumn fx:id="columnName" minWidth="400.0" prefWidth="600.0" text="NOME DO DEPARTAMENTO" />
          </columns>
          <columnResizePolicy>
             <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
          </columnResizePolicy>
        </TableView>
        
        <HBox alignment="CENTER_RIGHT">
            <Button onAction="#loadDepartments" style="-fx-background-color: transparent; -fx-text-fill: #34495E; -fx-border-color: #34495E; -fx-border-radius: 5; -fx-cursor: hand;" text="🔄 Atualizar Lista" />
        </HBox>
    </children>
</VBox>